# ==================================
# SHEBA BACKEND - Environment Configuration
# ==================================

# ==================================
# DJANGO CORE SETTINGS
# ==================================

# SECURITY WARNING: Generate a new secret key for production!
# Generate using: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-CHANGE-THIS-IN-PRODUCTION

# Debug mode (MUST be False in production)
DEBUG=True

# Allowed hosts (comma-separated)
# Development: localhost,127.0.0.1
# Production: yourdomain.com,your-server-ip
ALLOWED_HOSTS=localhost,127.0.0.1

# ==================================
# DATABASE CONFIGURATION
# ==================================

# Database engine (sqlite or postgresql)
DB_ENGINE=sqlite

# PostgreSQL Configuration (when DB_ENGINE=postgresql)
DB_NAME=sheba_db
DB_USER=sheba_user
DB_PASSWORD=your_strong_password_here
DB_HOST=localhost
DB_PORT=5432

# ==================================
# CORS CONFIGURATION
# ==================================

# Frontend URLs (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==================================
# TIMEZONE
# ==================================

# Application timezone
TIME_ZONE=Asia/Muscat

# ==================================
# GOOGLE OAUTH
# ==================================

# Google OAuth Client ID (from Google Cloud Console)
# Steps: Go to https://console.cloud.google.com/ > APIs & Services > Credentials > Create OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ==================================
# PRODUCTION SETTINGS
# ==================================

# For production deployment:
# 1. Set DEBUG=False
# 2. Set DB_ENGINE=postgresql
# 3. Generate new SECRET_KEY
# 4. Update ALLOWED_HOSTS with your domain/IP
# 5. Update CORS_ALLOWED_ORIGINS with your frontend URL
# 6. Configure SSL and secure cookies

